from transformers import AutoTokenizer, AutoModelForCausalLM
import torch

# Load GPU model (Mistral 7B)
model_name = "mistralai/Mistral-7B-Instruct-v0.2"
tokenizer = AutoTokenizer.from_pretrained(model_name)
model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=torch.float16,
    device_map="auto"
)

torch.backends.cudnn.benchmark = True
torch.backends.cuda.matmul.allow_tf32 = True

def generate_analysis(text):
    """Generate advanced, professional 4-section PDF analysis using LLM"""

    prompt = f"""
You are a professional PDF reviewer and document analyst.
Analyze the following document and provide a **concise, professional review** in **strict JSON format only** with the following four fields:
1. "summary": A short, clear summary of the document, condensing repeated statements.
2. "positive_points": At Least 4 Point A list of positive aspects, e.g., clarity, consistency, completeness, professionalism.
3. "negative_points": At Least 4 point A list of negative aspects, e.g., repetition, redundancy, lack of specific references, overformalization.
4. "how_to_avoid": Practical suggestions to avoid the negative points and improve the document quality.
Return **only JSON**, without any extra explanation or commentary.  
Use the following format strictly:
{{
  "summary": "Your summary here",
  "positive_points": ["point1", "point2","point3","point4"],
  "negative_points": ["point1", "point2","point3","point4"],
  "how_to_avoid": ["tip1", "tip2"]
}}
Document to analyze:
{text}
"""

    inputs = tokenizer(prompt, return_tensors="pt").to("cuda")
    output = model.generate(
        **inputs,
        max_new_tokens=500,   # increased for detailed JSON
        temperature=0.3,       # low for deterministic output
        do_sample=False
    )

    result = tokenizer.decode(output[0], skip_special_tokens=True)
    return result
